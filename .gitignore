# ============================================================
# .gitignore - סימולטור עסקת קומבינציה
# מסנן מה לא עולה לגיטהאב (ולכן גם לא לנטליפיי)
# ============================================================

# ===== קבצים רגישים פנימיים — אסור שיגיעו לאינטרנט =====
*.xlsx
*.xls
*.xlsm
*.pdf
*.docx
*.doc
*.pptx
*.ppt

# ===== קבצי עזר זמניים של Microsoft Office =====
~$*
*.tmp
*.bak

# ===== כלי פיתוח מקומיים — לא רלוונטיים לאתר החי =====
הפעל סימולטור.bat
*.bat

# ===== סכמת SQL פנימית (רק לתיעוד, לא משרת משתמשים) =====
supabase-schema.sql

# ===== מערכות הפעלה =====
.DS_Store
Thumbs.db
desktop.ini

# ===== עורכי קוד =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== תלויות (אם נוסיף בעתיד) =====
node_modules/
.env
.env.local

# ===== לוגים =====
*.log
npm-debug.log*

# ===== Claude Code (הגדרות מקומיות של כלי העוזר) =====
.claude/

# ===== תמונות עבודה פנימיות (לא חלק מהאתר) =====
בינוי על רקע חלקות.jpg
קומפילציה חלקות תוכנית בינוי גוש 3852.jpeg
